---
// Layout för den redaktionella granskningsvyn: rent läsmanus utan
// webbplatsens ordinarie navigation, granskningsrutor eller produktionsmetadata.
// Filnamn med inledande understreck routas inte av Astro.
//
// Vänsterspalten (permanent på desktop) är avgränsad till granskningsvyn
// (redaktionellt beslut) — den ordinarie Starlight-webbplatsens sidopanel
// (astro.config.mjs) är oförändrad. Navigeringsträdet byggs av anroparen ur
// samma hamtaReviewKapitel()-struktur som sidorna själva visar, så den kan
// aldrig gå ur synk med det faktiska manuset.
import { medBase } from '../../site-base.mjs';

const { titel, kapitel = [], aktivKapitelNr = null, aktivAnkare = null, expanderaAllt = false } = Astro.props;
---

<html lang="sv">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex, nofollow" />
		<title>{titel} · Granskningsmanus Teknik Gy25</title>
	</head>
	<body>
		<nav class="review-nav">
			<span class="review-etikett">Granskningsmanus · arbetsmaterial</span>
			<label for="nav-toggle" class="nav-toggle-label" aria-label="Öppna eller stäng innehållsförteckning">
				☰ Innehåll
			</label>
			<span class="review-lankar">
				<a href={medBase('/review/')}>Översikt</a>
				<a href={medBase('/review/hela-manuset/')}>Hela manuset</a>
			</span>
		</nav>

		<input type="checkbox" id="nav-toggle" class="nav-toggle-checkbox" />

		<div class="review-shell">
			<label for="nav-toggle" class="nav-scrim" aria-hidden="true"></label>
			<nav class="review-sidebar" aria-label="Manusstruktur">
				<p class="sidebar-rubrik">Innehåll</p>
				<ul>
					{kapitel.map((k) => (
						<li>
							<details open={expanderaAllt || k.nr === aktivKapitelNr}>
								<summary>
									<a
										href={medBase(`/review/kapitel-${k.nr}/`)}
										class={aktivKapitelNr === k.nr && !aktivAnkare ? 'active' : ''}
										aria-current={aktivKapitelNr === k.nr && !aktivAnkare ? 'page' : undefined}
									>
										Kapitel {k.nr} · {k.titel}
									</a>
								</summary>
								<ul>
									{k.avsnitt.map((avs) => (
										<li>
											<a
												href={medBase(`/review/kapitel-${k.nr}/#${avs.anchor}`)}
												class={aktivAnkare === avs.anchor ? 'active' : ''}
												aria-current={aktivAnkare === avs.anchor ? 'page' : undefined}
											>
												{avs.type ? avs.titel : `${avs.nr} ${avs.titel}`}
											</a>
										</li>
									))}
								</ul>
							</details>
						</li>
					))}
				</ul>
			</nav>

			<main class="review-main">
				<slot />
			</main>
		</div>

		<script is:inline>
			// Håller aktiv sida synlig i vänsterspalten utan att ändra sidans egen
			// scrollposition vid inladdning.
			const aktiv = document.querySelector('.review-sidebar a.active');
			if (aktiv) aktiv.scrollIntoView({ block: 'center' });
		</script>
	</body>
</html>

<style is:global>
	* { box-sizing: border-box; }
	html { color-scheme: light; }
	body {
		margin: 0;
		font-family: Georgia, 'Times New Roman', serif;
		font-size: 1.05rem;
		line-height: 1.65;
		color: #1a1a1a;
		background: #fff;
	}
	.review-nav {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		flex-wrap: wrap;
		padding: 0.8rem 1.25rem;
		border-bottom: 1px solid #ddd;
		font-family: system-ui, sans-serif;
		font-size: 0.85rem;
	}
	.review-etikett { color: #888; letter-spacing: 0.04em; text-transform: uppercase; }
	.review-lankar { display: flex; gap: 1.2rem; }
	.review-nav a { color: #234; text-decoration: none; }
	.review-nav a:hover { text-decoration: underline; }

	.nav-toggle-checkbox { display: none; }
	.nav-toggle-label {
		display: none;
		font-family: system-ui, sans-serif;
		font-size: 0.85rem;
		color: #234;
		cursor: pointer;
		user-select: none;
	}
	.nav-scrim { display: none; }

	.review-shell {
		display: flex;
		align-items: flex-start;
	}

	.review-sidebar {
		flex: 0 0 17rem;
		width: 17rem;
		position: sticky;
		top: 0;
		align-self: flex-start;
		max-height: 100vh;
		overflow-y: auto;
		padding: 1.25rem 1rem 2rem 1.25rem;
		border-right: 1px solid #e3e3e3;
		font-family: system-ui, sans-serif;
		font-size: 0.85rem;
		background: #fafafa;
	}
	.review-sidebar .sidebar-rubrik {
		margin: 0 0 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		font-size: 0.7rem;
		color: #888;
	}
	.review-sidebar ul { list-style: none; margin: 0; padding-left: 0.9rem; }
	.review-sidebar > ul { padding-left: 0; }
	.review-sidebar li { margin: 0.15rem 0; }
	.review-sidebar summary { cursor: pointer; list-style: revert; }
	.review-sidebar summary::marker { color: #888; }
	.review-sidebar summary a { display: inline; }
	.review-sidebar a {
		display: block;
		padding: 0.15rem 0.3rem;
		color: #333;
		text-decoration: none;
		border-radius: 0.25rem;
		line-height: 1.35;
	}
	.review-sidebar summary a { display: inline; padding: 0; }
	.review-sidebar a:hover { background: #eee; }
	.review-sidebar a.active {
		background: #1d3a5f;
		color: #fff;
		font-weight: 600;
	}

	.review-main {
		flex: 1 1 auto;
		min-width: 0;
		max-width: 46rem;
		margin: 0 auto;
		padding: 0 1.25rem 6rem;
	}

	h1 { font-size: 1.75rem; line-height: 1.35; margin: 3.5rem 0 1rem; }
	h2 { font-size: 1.4rem; margin: 3rem 0 0.8rem; color: #222; }
	h3 { font-size: 1.2rem; margin: 2.6rem 0 0.7rem; }
	h4 { font-size: 1.05rem; font-weight: 400; font-style: italic; color: #1a1a1a; line-height: 1.35; margin: 1.7rem 0 0; }
	h4 + p, h4 + ul, h4 + ol { margin-top: 0.6rem; }
	h5, h6 { font-size: 1rem; margin: 1.5rem 0 0.4rem; }
	article.larandemal { border-top: 1px solid #e3e3e3; margin-top: 3rem; }
	article.larandemal:first-of-type { border-top: none; margin-top: 0; }
	table { border-collapse: collapse; margin: 1.2rem 0; }
	th, td { border: 1px solid #bbb; padding: 0.35rem 0.7rem; }
	ol { padding-left: 1.5rem; }
	.review-main a { color: #1d3a5f; }
	.review-toc { font-family: system-ui, sans-serif; font-size: 0.95rem; }
	.review-toc ul { list-style: none; padding-left: 1.1rem; }
	.review-toc > ul { padding-left: 0; }
	.review-toc a { text-decoration: none; }
	.review-toc a:hover { text-decoration: underline; }
	.review-toc .toc-kapitel { margin-top: 0.9rem; font-weight: 600; }
	.review-toc .toc-avsnitt { margin-top: 0.4rem; font-weight: 600; font-size: 0.9rem; color: #444; }
	.review-toc .toc-lm { font-weight: 400; }
	.review-titelblad { text-align: center; margin: 3.5rem 0 4rem; }
	.review-titelblad h1 { margin-bottom: 0.4rem; }
	.review-titelblad p { color: #666; margin: 0.25rem 0; }
	.kapitelnav { display: flex; justify-content: space-between; gap: 1rem; margin-top: 4rem;
		padding-top: 1rem; border-top: 1px solid #ddd; font-family: system-ui, sans-serif; font-size: 0.9rem; }

	@media (max-width: 900px) {
		.nav-toggle-label { display: inline-block; }
		.review-sidebar {
			position: fixed;
			top: 0;
			left: 0;
			bottom: 0;
			z-index: 20;
			transform: translateX(-100%);
			transition: transform 0.2s ease;
			box-shadow: 0.25rem 0 1rem rgba(0, 0, 0, 0.15);
			max-height: 100vh;
		}
		.nav-toggle-checkbox:checked ~ .review-shell .review-sidebar {
			transform: translateX(0);
		}
		.nav-toggle-checkbox:checked ~ .review-shell .nav-scrim {
			display: block;
			position: fixed;
			inset: 0;
			background: rgba(0, 0, 0, 0.3);
			z-index: 10;
		}
	}

	@media (max-width: 640px) {
		.review-main { font-size: 1rem; padding: 0 1rem 4rem; }
		h1 { font-size: 1.5rem; }
	}

	@media print {
		.review-nav, .kapitelnav, .review-sidebar, .nav-toggle-label { display: none; }
		.review-main { max-width: none; padding: 0; font-size: 11pt; color: #000; }
		article.larandemal { border-top: none; break-before: page; page-break-before: always; }
		article.larandemal:first-of-type { break-before: auto; page-break-before: auto; }
		.review-main a { color: inherit; text-decoration: none; }
		h1, h2, h3, h4 { break-after: avoid; page-break-after: avoid; }
	}
</style>
