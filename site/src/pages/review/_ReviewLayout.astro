---
// Layout för den redaktionella granskningsvyn: rent läsmanus utan
// webbplatsens navigation, granskningsrutor eller produktionsmetadata.
// Filnamn med inledande understreck routas inte av Astro.
import { medBase } from '../../site-base.mjs';

const { titel } = Astro.props;
---

<html lang="sv">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex, nofollow" />
		<title>{titel} · Granskningsmanus Teknik Gy25</title>
	</head>
	<body>
		<nav class="review-nav">
			<span class="review-etikett">Granskningsmanus · arbetsmaterial</span>
			<span class="review-lankar">
				<a href={medBase('/review/')}>Översikt</a>
				<a href={medBase('/review/hela-manuset/')}>Hela manuset</a>
			</span>
		</nav>
		<main>
			<slot />
		</main>
	</body>
</html>

<style is:global>
	* { box-sizing: border-box; }
	html { color-scheme: light; }
	body {
		max-width: 46rem;
		margin: 0 auto;
		padding: 0 1.25rem 6rem;
		font-family: Georgia, 'Times New Roman', serif;
		font-size: 1.05rem;
		line-height: 1.65;
		color: #1a1a1a;
		background: #fff;
	}
	.review-nav {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		flex-wrap: wrap;
		padding: 0.8rem 0;
		margin-bottom: 2.5rem;
		border-bottom: 1px solid #ddd;
		font-family: system-ui, sans-serif;
		font-size: 0.85rem;
	}
	.review-etikett { color: #888; letter-spacing: 0.04em; text-transform: uppercase; }
	.review-lankar { display: flex; gap: 1.2rem; }
	.review-nav a { color: #234; text-decoration: none; }
	.review-nav a:hover { text-decoration: underline; }
	h1 { font-size: 1.75rem; line-height: 1.25; margin: 3.5rem 0 1rem; }
	h2 { font-size: 1.4rem; margin: 3rem 0 0.8rem; color: #222; }
	h3 { font-size: 1.2rem; margin: 2.6rem 0 0.7rem; }
	h4 { font-size: 1.05rem; margin: 1.9rem 0 0.5rem; }
	h5, h6 { font-size: 1rem; margin: 1.5rem 0 0.4rem; }
	article.larandemal { border-top: 1px solid #e3e3e3; margin-top: 3rem; }
	article.larandemal:first-of-type { border-top: none; margin-top: 0; }
	table { border-collapse: collapse; margin: 1.2rem 0; }
	th, td { border: 1px solid #bbb; padding: 0.35rem 0.7rem; }
	ol { padding-left: 1.5rem; }
	a { color: #1d3a5f; }
	.review-toc { font-family: system-ui, sans-serif; font-size: 0.95rem; }
	.review-toc ul { list-style: none; padding-left: 1.1rem; }
	.review-toc > ul { padding-left: 0; }
	.review-toc a { text-decoration: none; }
	.review-toc a:hover { text-decoration: underline; }
	.review-toc .toc-kapitel { margin-top: 0.9rem; font-weight: 600; }
	.review-toc .toc-modul { margin-top: 0.4rem; font-weight: 600; font-size: 0.9rem; color: #444; }
	.review-toc .toc-lm { font-weight: 400; }
	.review-titelblad { text-align: center; margin: 3.5rem 0 4rem; }
	.review-titelblad h1 { margin-bottom: 0.4rem; }
	.review-titelblad p { color: #666; margin: 0.25rem 0; }
	.kapitelnav { display: flex; justify-content: space-between; gap: 1rem; margin-top: 4rem;
		padding-top: 1rem; border-top: 1px solid #ddd; font-family: system-ui, sans-serif; font-size: 0.9rem; }

	@media (max-width: 640px) {
		body { font-size: 1rem; padding: 0 1rem 4rem; }
		h1 { font-size: 1.5rem; }
	}

	@media print {
		body { max-width: none; padding: 0; font-size: 11pt; color: #000; }
		.review-nav, .kapitelnav { display: none; }
		article.larandemal { border-top: none; break-before: page; page-break-before: always; }
		article.larandemal:first-of-type { break-before: auto; page-break-before: auto; }
		a { color: inherit; text-decoration: none; }
		h1, h2, h3, h4 { break-after: avoid; page-break-after: avoid; }
	}
</style>
