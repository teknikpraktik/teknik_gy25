---
// Kapitelvis granskningsvy: primär läsvy. En statisk sida per kapitel som
// har minst ett lärandemål i status fardig-forsta-version eller högre.
// Alla routes genereras vid bygget via getStaticPaths.
import ReviewLayout from './_ReviewLayout.astro';
import { hamtaReviewKapitel } from './_data.mjs';
import { medBase } from '../../site-base.mjs';

export async function getStaticPaths() {
	const kapitel = await hamtaReviewKapitel();
	return kapitel.map((k, idx) => ({
		params: { nr: String(k.nr) },
		props: {
			kapitel: k,
			foregaende: idx > 0 ? kapitel[idx - 1] : null,
			nasta: idx < kapitel.length - 1 ? kapitel[idx + 1] : null,
		},
	}));
}

const { kapitel: k, foregaende, nasta } = Astro.props;
---

<ReviewLayout titel={`Kapitel ${k.nr} · ${k.titel}`}>
	<h1>Kapitel {k.nr} · {k.titel}</h1>

	{k.moduler.map((m) => (
		<section>
			<h2 id={m.anchor}>{m.nr} {m.titel}</h2>
			{m.larandemal.map((lm) => (
				<article class="larandemal">
					<h3 id={lm.anchor}>{lm.titel}</h3>
					<Fragment set:html={lm.html} />
				</article>
			))}
		</section>
	))}

	<nav class="kapitelnav" aria-label="Kapitelnavigering">
		<span>{foregaende && <a href={medBase(`/review/kapitel-${foregaende.nr}/`)}>← Kapitel {foregaende.nr} · {foregaende.titel}</a>}</span>
		<span>{nasta && <a href={medBase(`/review/kapitel-${nasta.nr}/`)}>Kapitel {nasta.nr} · {nasta.titel} →</a>}</span>
	</nav>
</ReviewLayout>
