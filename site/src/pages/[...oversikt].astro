---
// Genererad översiktsvy för ett kapitel. Sidan härleds vid varje bygge ur
// 06-bokstruktur.md (via bokstruktur-data.mjs), avsnittens frontmatter
// (content collection) och kursplan-data.mjs — den lagras aldrig som en fil i
// content/ och kan därför inte gå ur synk eller visa cachad, inaktuell status
// (till skillnad från renderade markdown-sidor).
//
// Vyn stödjer kapitelgranskning enligt 09-kvalitetssakring.md ("Granskning av
// kapitel") och kursplanetäckning (07-kursplanetackning.md). Det finns ingen
// motsvarande modulvy längre — avsnittet (H2) är den minsta enheten, och dess
// egen sida visar redan lärandemål och begrepp i granskningsrutan
// (remark-granskning.mjs).

import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { getCollection } from 'astro:content';
import { kapitel, kapitelSlug, avsnittFilnamn, routeSegment } from '../../../scripts/bokstruktur-data.mjs';
import { niva1, niva2, syftesmal } from '../../../scripts/kursplan-data.mjs';
import { medBase } from '../site-base.mjs';

export async function getStaticPaths() {
	return kapitel.map((k) => ({ params: { oversikt: kapitelSlug(k) }, props: { kapNr: k.nr } }));
}

const { kapNr } = Astro.props;
const k = kapitel.find((x) => x.nr === kapNr);

const docs = await getCollection('docs');
const fmById = new Map(docs.filter((e) => e.data.id !== undefined).map((e) => [e.data.id, e.data]));
const kapAvslutDocs = docs.filter((e) => e.data.type !== undefined && e.data.chapter === k.nr);

// Begreppens huvudställen, för kontroll av introduktionsordning (09, 11).
const begreppsAgare = new Map();
for (const [id, fm] of fmById) {
	for (const namn of fm.concepts_introduced ?? []) begreppsAgare.set(namn, id);
}
function jamforIds(a, b) {
	const ta = a.split('.').map(Number);
	const tb = b.split('.').map(Number);
	for (let i = 0; i < Math.max(ta.length, tb.length); i++) {
		const diff = (ta[i] ?? 0) - (tb[i] ?? 0);
		if (diff !== 0) return diff;
	}
	return 0;
}

const kapUrl = medBase(`/${kapitelSlug(k)}/`);
const avsUrl = (i) => medBase(`/${kapitelSlug(k)}/${routeSegment(avsnittFilnamn(k, i).replace(/\.md$/, ''))}/`);

// Teoriavsnitt (utan kapitelavslutningarna) med sin frontmatter, för tabell och begreppsflöde.
const teoriavsnitt = k.avsnitt
	.map((avs, i) => ({ i, plan: avs, id: `${k.nr}.${i + 1}`, fm: fmById.get(`${k.nr}.${i + 1}`) }))
	.filter((r) => !r.plan.type);

const kapitelTotal = {
	antal: teoriavsnitt.length,
	paborjade: teoriavsnitt.filter((r) => r.fm && r.fm.status !== 'ej-paborjad').length,
	klara: teoriavsnitt.filter((r) => r.fm?.status === 'klar').length,
};

// Kursplanansvar.
const allaPunkterLista = [
	...niva1.map((p) => ({ ...p, niva: 'Nivå 1' })),
	...niva2.map((p) => ({ ...p, niva: 'Nivå 2' })),
	...syftesmal.map((p) => ({ ...p, niva: 'Syftesmål' })),
];
const kapitletsAvsnitt = [...fmById.values()].filter((d) => d.chapter === k.nr);
function tackning(p) {
	const taggade = kapitletsAvsnitt.filter((d) =>
		[...(d.curriculumReferences?.niva1 ?? []), ...(d.curriculumReferences?.niva2 ?? [])].includes(p.id),
	);
	return { taggade: taggade.length, paborjade: taggade.filter((d) => d.status !== 'ej-paborjad').length };
}
const primara = allaPunkterLista.filter((p) => p.primar === k.nr);
const berorda = allaPunkterLista.filter((p) => Array.isArray(p.berors) && p.berors.includes(k.nr));
const lopande = allaPunkterLista.filter((p) => p.berors.includes('löpande') && p.primar !== k.nr);

// Kapitelavslutningar, i 06:s ordning (alltid de tre sista avsnitten).
const kapAvslutningar = k.avsnitt
	.map((avs, i) => ({ avs, i }))
	.filter((r) => r.avs.type)
	.map(({ avs, i }) => {
		const doc = kapAvslutDocs.find((e) => e.data.type === avs.type);
		return {
			type: avs.type,
			title: avs.titel,
			status: doc?.data?.status,
			finns: !!doc,
			url: avsUrl(i),
		};
	});

const titel = `Kapitel ${k.nr} · ${k.titel}`;

// Checklista ur 09-kvalitetssakring.md (påminnelse för granskaren; bockas inte
// av digitalt — granskningen dokumenteras via statusfältet).
const kapitelChecklista = [
	'Kapitlets syfte uppfylls.',
	'Avsnitten ligger i logisk ordning.',
	'Kapitlet täcker sitt ansvar enligt innehållsmatrisen.',
	'Praktiska moment förekommer där de passar.',
	'Exempel varierar.',
	'Kapitlet känns jämnt i kvalitet.',
];
---

<StarlightPage frontmatter={{ title: titel, tableOfContents: false }}>
	<p class="oversikt-meta">
		{kapitelTotal.antal} avsnitt · {kapitelTotal.paborjade} påbörjade, {kapitelTotal.klara} klara
	</p>

	<h2>Avsnitt</h2>
	<table>
		<thead>
			<tr>
				<th>Avsnitt</th>
				<th>Lärandemål</th>
				<th>Status</th>
			</tr>
		</thead>
		<tbody>
			{
				teoriavsnitt.map((r) => (
					<tr>
						<td>
							<a href={avsUrl(r.i)}>
								{r.id} {r.plan.titel}
							</a>
						</td>
						<td>{r.fm?.learningGoals?.length ?? r.plan.larandemal.length}</td>
						<td>
							{r.fm ? (
								<span class={`gr-status gr-status-${r.fm.status}`}>{r.fm.status}</span>
							) : (
								<span class="gr-dammig">fil saknas!</span>
							)}
						</td>
					</tr>
				))
			}
		</tbody>
	</table>

	<h2>Begreppsflöde</h2>
	<p class="oversikt-meta">
		För granskning av begreppsordningen (09, 11). "Introduceras senare" markerar begrepp som används före sitt
		huvudställe i läsordningen.
	</p>
	<ul class="begreppsflode">
		{
			teoriavsnitt.map((r) => (
				<li>
					<strong>
						{r.id} {r.plan.titel}
					</strong>
					{' — introducerar: '}
					{(r.fm?.concepts_introduced ?? []).join(', ') || '—'}
					{' · använder: '}
					{(r.fm?.concepts_used ?? []).length === 0
						? '—'
						: (r.fm?.concepts_used ?? []).map((namn, idx) => {
								const agare = begreppsAgare.get(namn);
								const sen = agare && jamforIds(agare, r.id) >= 0;
								return (
									<>
										{idx > 0 && ', '}
										{namn}
										{!agare && <span class="gr-varning"> (saknar huvudställe)</span>}
										{sen && <span class="gr-varning"> (introduceras senare: {agare}!)</span>}
									</>
								);
							})}
				</li>
			))
		}
	</ul>

	<h2>Kursplanansvar (07-kursplanetackning.md)</h2>
	{
		primara.length > 0 && (
			<>
				<h3>● Primärt ansvar</h3>
				<table>
					<thead>
						<tr>
							<th>Id</th>
							<th>Punkt</th>
							<th>Nivå</th>
							<th>Taggade avsnitt</th>
						</tr>
					</thead>
					<tbody>
						{primara.map((p) => {
							const t = tackning(p);
							return (
								<tr>
									<td>{p.id}</td>
									<td>{p.text}</td>
									<td>{p.niva}</td>
									<td>
										{t.taggade} ({t.paborjade} påbörjade)
									</td>
								</tr>
							);
						})}
					</tbody>
				</table>
			</>
		)
	}
	{
		berorda.length > 0 && (
			<>
				<h3>○ Berörs / vävs in</h3>
				<table>
					<thead>
						<tr>
							<th>Id</th>
							<th>Punkt</th>
							<th>Nivå</th>
							<th>Taggade avsnitt</th>
						</tr>
					</thead>
					<tbody>
						{berorda.map((p) => {
							const t = tackning(p);
							return (
								<tr>
									<td>{p.id}</td>
									<td>{p.text}</td>
									<td>{p.niva}</td>
									<td>
										{t.taggade} ({t.paborjade} påbörjade)
									</td>
								</tr>
							);
						})}
					</tbody>
				</table>
			</>
		)
	}
	{
		lopande.length > 0 && (
			<p class="oversikt-meta">
				Löpande trådar som ska synas i varje kapitel (07, svag punkt 3): {lopande.map((p) => p.id).join(', ')} —
				normer, genus och etik vävs in där de är relevanta, inte bara i kapitel 13.
			</p>
		)
	}

	{
		kapAvslutningar.length > 0 && (
			<>
				<h2>Kapitelavslutningar</h2>
				<ul>
					{kapAvslutningar.map((a) => (
						<li>
							{a.finns ? <a href={a.url}>{a.title}</a> : a.title}{' '}
							<span class="gr-dammig">
								({a.type}
								{a.status ? `, ${a.status}` : ', fil saknas'})
							</span>
						</li>
					))}
				</ul>
			</>
		)
	}

	<h2>Kapitelgranskning (09-kvalitetssakring.md)</h2>
	<ul class="checklista">
		{kapitelChecklista.map((punkt) => (
			<li>☐ {punkt}</li>
		))}
	</ul>
</StarlightPage>
